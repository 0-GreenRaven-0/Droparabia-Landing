    font-size: clamp(1.875rem, 4vw, 2.625rem);
    font-weight: normal;
    color: #0f172a;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 36px;
  }

  .brand-inline {
    font-family: var(--font-brand);
    color: #2563eb;
    font-weight: normal;
  }

  .video-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    aspect-ratio: 16 / 9;
  }

  .video-wrap iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
