---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>Book Your Call — Droparabia</title>
    <link rel="icon" type="image/png" href="/Droparabia.png" />
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
      .flex { display: flex; } .items-center { align-items: center; } .justify-center { justify-content: center; }
      .flex-col { flex-direction: column; } .p-4 { padding: 1rem; } .min-h-screen { min-height: 100vh; }
      .w-full { width: 100%; } .max-w-4xl { max-width: 56rem; } .gap-6 { gap: 1.5rem; }
      .text-center { text-align: center; } .gap-3 { gap: 0.75rem; } .gap-2 { gap: 0.5rem; }
      .font-bold { font-weight: 700; } .font-semibold { font-weight: 600; }
      .input--hidden { display: none !important; }
    </style>
  </head>

  <body style="background:#e0e0e0; min-height:100vh;">

    <!-- Shown if no valid token -->
    <div id="no-access" style="display:none; min-height:100vh; display:none; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:2rem; text-align:center;">
      <h1 style="font-size:1.75rem; font-weight:700; color:#111827;">No cheating allowed! 😏</h1>
      <p style="font-size:1.1rem; color:#374151;">Please go back and finish the survey first.</p>
      <button onclick="window.location.href='/survey'" style="margin-top:1rem; padding:0.75rem 2rem; background:linear-gradient(135deg,#2563EB,#3B82F6); color:#fff; font-weight:700; border:none; border-radius:10px; font-size:1rem; cursor:pointer;">
        Go Back
      </button>
    </div>

    <div id="main-content" style="display:none;">
    <div class="flex items-center justify-center p-4" style="padding-top:0.5rem; padding-bottom:2rem;">
      <div class="w-full max-w-4xl" style="display:flex; flex-direction:column; gap:1.5rem;">

        <!-- Header -->
        <div style="text-align:center; display:flex; flex-direction:column; gap:0.5rem; margin-bottom:0.5rem;">
          <h1 style="font-size:clamp(1.75rem,3vw,2.5rem); font-weight:700; color:#2563EB;">
            We're a good fit for you! 
          </h1>
          <h3 style="font-size:1.1rem; font-weight:600; color:#1f2937;">
            Our team is looking forward to get you started on building your business!
          </h3>
          <p style="color:#4B5563;">Select an available time that best suits you</p>

        </div>

        <!-- Calendly inline widget -->
        <div style="position:relative;">
          <!-- Loading skeleton -->
          <div id="calendly-loader" style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:3rem 1rem; background:#fff; border-radius:16px;">
            <div style="width:48px; height:48px; border:4px solid #E2E8F0; border-top-color:#2563EB; border-radius:50%; animation:spin 0.8s linear infinite;"></div>
            <p style="color:#6B7280; font-size:1rem; font-family:'Inter',sans-serif;">Loading available times...</p>
          </div>
          <div id="calendly-widget" class="calendly-inline-widget" style="min-width:320px; height:1100px; display:none;"></div>
        </div>
        <style is:inline>
          @keyframes spin { to { transform: rotate(360deg); } }
        </style>

      </div>
    </div>
    </div> <!-- /main-content -->


    <!-- Token check + Calendly init -->
    <script is:inline>
      (function() {
        try {
          const tokens = JSON.parse(sessionStorage.getItem('userTokens') || '{}');
          if (tokens.qualified) {
            document.getElementById('main-content').style.display = 'block';
            Calendly.initInlineWidget({
              url: 'https://calendly.com/d/cx6h-n22-cr7/45-min-droparabia-advisory-call',
              parentElement: document.getElementById('calendly-widget'),
            });
            // Hide loader once Calendly signals it's ready
            window.addEventListener('message', function onCalendlyLoad(e) {
              if (e.data && (e.data.event === 'calendly.profile_page_viewed' || e.data.event === 'calendly.event_type_viewed')) {
                document.getElementById('calendly-loader').style.display = 'none';
                document.getElementById('calendly-widget').style.display = 'block';
                window.removeEventListener('message', onCalendlyLoad);
              }
            });
            // Fallback: show after 5s regardless
            setTimeout(function() {
              document.getElementById('calendly-loader').style.display = 'none';
              document.getElementById('calendly-widget').style.display = 'block';
            }, 5000);
          } else {
            document.getElementById('no-access').style.display = 'flex';
          }
        } catch(_) {
          document.getElementById('no-access').style.display = 'flex';
        }
      })();
    </script>

    <!-- canvas-confetti CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <!-- Confetti + conditional Brevo subscription -->
    <script is:inline>
async function silentBrevoSubmit(list) {
        try {
          var userData = JSON.parse(sessionStorage.getItem('userData') || '{}');
          if (!userData.email) return;
          await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: userData.name, email: userData.email, phone: userData.phone, list: list }),
            keepalive: true,
          });
        } catch(_) {}
      }

      document.addEventListener('DOMContentLoaded', function() {
        // Confetti
        setTimeout(function() {
          confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
          setTimeout(function() { confetti({ particleCount: 50, angle: 60,  spread: 55, origin: { x: 0 } }); }, 250);
          setTimeout(function() { confetti({ particleCount: 50, angle: 120, spread: 55, origin: { x: 1 } }); }, 400);
          setTimeout(function() { confetti({ particleCount: 30, spread: 100, decay: 0.91, scalar: 1.2, shapes: ['star'] }); }, 600);
          var end = Date.now() + 3000;
          (function frame() {
            confetti({ particleCount: 2, angle: 60, spread: 55, origin: { x: Math.random() }, colors: ['#3b82f6','#10b981','#f59e0b','#ef4444'] });
            if (Date.now() < end) requestAnimationFrame(frame);
          }());
        }, 300);
      });

      var callBooked = false;

      window.addEventListener('message', function(e) {
        if (e.data && e.data.event === 'calendly.event_scheduled') {
          if (callBooked) return;
          callBooked = true;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'call_booked' });
          silentBrevoSubmit('booked').then(function() {
            window.location.href = 'https://thank-you.droparabia.com';
          });
        }
      });

      window.addEventListener('beforeunload', function() {
        if (!callBooked) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'call_not_booked' });
        }
      });
    </script>

  </body>
</html>
