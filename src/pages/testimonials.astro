<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  const swiperIds = ['cs-swiper-1', 'cs-swiper-2', 'cs-swiper-3', 'cs-swiper-4'];

  swiperIds.forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;
    new Swiper(el, {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        768: { slidesPerView: 3, spaceBetween: 24 },
      },
      loop: false,
      autoplay: false,
      navigation: {
        nextEl: el.querySelector('.swiper-button-next') as HTMLElement,
        prevEl: el.querySelector('.swiper-button-prev') as HTMLElement,
      },
      pagination: { el: el.querySelector('.swiper-pagination') as HTMLElement, clickable: true },
    });
  });
</script>

