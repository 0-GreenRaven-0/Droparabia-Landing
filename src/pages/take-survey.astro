---

import Survey from '../components/Survey.jsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>Survey — Droparabia</title>
    <link rel="icon" type="image/png" href="/Droparabia.png" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: #F1F5F9; min-height: 100vh; -webkit-font-smoothing: antialiased; }
      .survey-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.25rem 1rem; min-height: 100svh; }
      .survey-card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 1.75rem; width: 100%; max-width: 680px; }
      .survey-title { color: #2563EB; font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 0.5rem; }
      .survey-progress-track { background: #E2E8F0; height: 6px; border-radius: 999px; margin-bottom: 0.9rem; overflow: hidden; }
      .survey-progress-bar { background: linear-gradient(90deg, #2563EB, #3B82F6); height: 100%; border-radius: 999px; transition: width 0.5s ease; }
      .survey-page-count { color: #94A3B8; font-size: 0.9rem; margin-bottom: 1rem; }
      .survey-questions-wrap { position: relative; overflow: hidden; min-height: 180px; }
      .survey-question { font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 1rem; line-height: 1.6; }
      .survey-options { display: flex; flex-direction: column; gap: 0.6rem; }
      .survey-option { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 12px; border: 2px solid #E2E8F0; background: #fff; cursor: pointer; transition: border-color 0.15s, background 0.15s, transform 0.15s; font-weight: 500; color: #111827; }
      .survey-option:hover { border-color: #93C5FD; background: #EFF6FF; transform: translateX(3px); }
      .survey-option--selected { border-color: #2563EB; background: #EFF6FF; box-shadow: 0 2px 8px rgba(37,99,235,0.12); }
      .survey-radio { appearance: none; display: none; }
      .survey-error { color: #DC2626; font-size: 0.85rem; margin-top: 0.25rem; }
      .survey-error--field { background: #FEF2F2; border: 1px solid #FCA5A5; border-radius: 8px; padding: 0.5rem 0.75rem; margin-top: 0.75rem; }
      .survey-nav { display: flex; gap: 0.75rem; margin-top: 1.75rem; }
      .survey-btn { padding: 0.75rem 1.75rem; background: linear-gradient(135deg, #2563EB, #3B82F6); color: #fff; font-weight: 700; border-radius: 10px; border: none; cursor: pointer; font-size: 1rem; font-family: 'Inter', sans-serif; }
      .survey-btn--secondary { background: #fff; color: #2563EB; border: 2px solid #2563EB; box-shadow: none; }
    </style>
  </head>
  <body>
    <Survey client:load />
  </body>
</html>
