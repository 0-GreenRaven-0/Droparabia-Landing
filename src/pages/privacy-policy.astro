    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: #f8fafc; color: #1f2937; }

      .pp-nav { background: #0f172a; padding: 16px 24px; display: flex; align-items: center; }
      .pp-nav-logo { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
      .pp-nav-logo-img { width: 40px; height: 40px; object-fit: contain; border-radius: 8px; }
      .pp-nav-logo-name { color: #fff; font-size: 1.5rem; font-weight: 700; }

      .pp-main { max-width: 720px; margin: 0 auto; padding: 56px 24px 80px; }
      .pp-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; color: #0B1729; margin: 0 0 1.5rem; }
      .pp-lead { font-size: 1.05rem; line-height: 1.75; color: #374151; margin: 0 0 2.5rem; border-left: 3px solid #2563eb; padding-left: 1rem; }
      .pp-section { margin-bottom: 2rem; }
      .pp-heading { font-size: 1.05rem; font-weight: 700; color: #0B1729; margin: 0 0 0.6rem; }
      .pp-text { font-size: 0.975rem; line-height: 1.75; color: #374151; margin: 0 0 0.75rem; }
      .pp-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
      .pp-list li { font-size: 0.975rem; line-height: 1.7; color: #374151; padding-left: 1.25rem; position: relative; }
      .pp-list li::before { content: '•'; position: absolute; left: 0; color: #2563eb; font-weight: 700; }
      .pp-link { color: #2563eb; text-decoration: underline; }
      .pp-link:hover { color: #1d4ed8; }

      .footer { background: #0f172a; padding: 48px 24px 0; }
      .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 32px; max-width: 1040px; margin: 0 auto; padding-bottom: 32px; border-bottom: 1px solid rgba(255,255,255,0.1); }
      .footer-brand { display: flex; flex-direction: column; gap: 12px; }
      .footer-logo-link { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
      .footer-logo-img { width: 40px; height: 40px; object-fit: contain; border-radius: 8px; }
      .footer-logo-name { color: #fff; font-size: 1.5rem; font-weight: 700; }
      .footer-links { display: flex; flex-direction: column; gap: 12px; }
      .footer-links-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b; margin: 0; }
      .footer-compliance { display: flex; flex-direction: column; gap: 8px; }
      .footer-compliance-link { color: #fff; text-decoration: none; font-size: 0.9rem; transition: opacity 0.15s; }
      .footer-compliance-link:hover { opacity: 0.75; }
      .footer-socials { display: flex; align-items: center; gap: 10px; }
      .footer-social-link { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: rgba(255,255,255,0.07); color: #94a3b8; border-radius: 8px; text-decoration: none; transition: all 0.15s; }
      .footer-social-link svg { width: 18px; height: 18px; }
      .footer-social-link:hover { background: rgba(255,255,255,0.14); color: #fff; }
      .footer-bottom { max-width: 1040px; margin: 0 auto; padding: 20px 0; }
      .footer-bottom p { font-size: 0.8125rem; color: #64748b; margin: 0; }

      @media (max-width: 768px) {
        .footer-inner { flex-direction: column; gap: 24px; }
      }
    </style>
  </head>

