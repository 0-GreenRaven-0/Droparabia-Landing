    <!-- NAV -->
    <header class="pp-nav">
      <a href="/" class="pp-nav-logo">
        <img src="/Droparabia.png" alt="Droparabia" class="pp-nav-logo-img" />
        <span class="pp-nav-logo-name">Droparabia</span>
      </a>
    </header>

    <!-- CONTENT -->
    <main class="pp-main">
      <h1 class="pp-title">Privacy Policy</h1>

      <p class="pp-lead">Droparabia is committed to protecting your personal information. This Privacy Policy explains what data we collect, how we use it, and how we keep it safe when you visit droparabia.com or register for our free live workshop.</p>

      <section class="pp-section">
        <h2 class="pp-heading">1. Information We Collect</h2>
        <ul class="pp-list">
          <li>Personal Data (name, email address, phone number)</li>
          <li>Usage Data (pages visited, time spent, links clicked, funnel stage)</li>
        </ul>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">2. How We Use Your Information</h2>
        <ul class="pp-list">
          <li>To process your registration and provide access to our workshop and platform</li>
          <li>To communicate with you regarding your account, follow-ups, and updates</li>
          <li>To improve our content, offers, and user experience</li>
          <li>To qualify leads and organize them based on their funnel journey</li>
          <li>For legal compliance and security purposes</li>
        </ul>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">3. Cookies and Tracking</h2>
        <p class="pp-text">We use cookies and third-party analytics tools including Google Analytics and Google Tag Manager to understand user behavior and improve site performance.</p>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">4. Data Sharing</h2>
        <p class="pp-text">We do not sell or rent your personal data. We only share data with trusted third-party services (Brevo, Google Sheets, Calendly) when necessary to operate our platform.</p>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">5. Data Security</h2>
        <p class="pp-text">We use encryption and secure platforms to protect your data. While no system is 100% secure, we do our best to safeguard your information.</p>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">6. Your Rights</h2>
        <p class="pp-text">You can request to access, correct, or delete your data at any time by reaching out to us on Instagram at <a href="https://www.instagram.com/mjbusinessofficial" target="_blank" rel="noopener" class="pp-link">@mjbusinessofficial</a>.</p>
      </section>

      <section class="pp-section">
        <h2 class="pp-heading">7. Policy Updates</h2>
        <p class="pp-text">This Privacy Policy may change from time to time. The most recent version will always be posted on this page.</p>
        <p class="pp-text">If you have questions, please reach out to us on Instagram at <a href="https://www.instagram.com/mjbusinessofficial" target="_blank" rel="noopener" class="pp-link">@mjbusinessofficial</a>.</p>
      </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo-link">
            <img src="/Droparabia.png" alt="Droparabia logo" class="footer-logo-img" />
            <span class="footer-logo-name">Droparabia</span>
          </a>
        </div>
        <div class="footer-links">
          <p class="footer-links-label">Legal</p>
          <div class="footer-compliance">
            <a href="/privacy-policy" class="footer-compliance-link">Privacy Policy</a>
            <a href="/terms" class="footer-compliance-link">Terms &amp; Conditions</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 Droparabia. All rights reserved.</p>
      </div>
    </footer>

