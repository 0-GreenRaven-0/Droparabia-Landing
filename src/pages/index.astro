<script>
  // @ts-ignore
  import Plyr from 'plyr';
  import 'plyr/dist/plyr.css';
  declare global { interface Window { dataLayer: unknown[] } }

  function getTrackingData(): Record<string, string> {
    const result: Record<string, string> = {};
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(k => {
      const v = sessionStorage.getItem(k); if (v) result[k] = v;
    });
    const ref = sessionStorage.getItem('da_referrer');
    if (ref) result.referrer = ref;
    return result;
  }

  console.log('[DA] Plyr script running, video el:', document.getElementById('vsl-player'));

  const player = new Plyr('#vsl-player', {
    controls: ['play-large', 'play', 'mute', 'volume'],
    resetOnEnd: false,
    speed: { selected: 1.2, options: [0.75, 1, 1.1, 1.2] },
  });

  player.on('ready', () => {
    document.getElementById('vsl-pre-init')?.remove();
  });

  // Auto speed: start at 1.2x, step down every 30s after the 1-min mark
  // 0:00–1:00 → 1.2x | 1:00–1:30 → 1.1x | 1:30+ → 1.0x
  let speedStage = 0; // 0 = fast, 1 = mid, 2 = normal
  player.on('timeupdate', () => {
    const t = player.currentTime;
    if (t < 60 && speedStage !== 0) {
      speedStage = 0;
      player.speed = 1.2;
    } else if (t >= 60 && t < 90 && speedStage !== 1) {
      speedStage = 1;
      player.speed = 1.1;
    } else if (t >= 90 && speedStage !== 2) {
      speedStage = 2;
      player.speed = 1;
    }
  });

  // Fire video_complete when user reaches 80% of the video
  let videoCompleteTracked = false;
  player.on('timeupdate', () => {
    const dur = player.duration;
    if (!videoCompleteTracked && dur > 0 && player.currentTime >= dur * 0.8) {
      videoCompleteTracked = true;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'video_complete' });
    }
  });

  player.on('ready', () => {
    player.speed = 1.2;
    player.media.setAttribute('preload', 'auto');
  });

  if (sessionStorage.getItem('da_subscribed')) {
    document.getElementById('vsl-inline-gate')?.remove();
    document.querySelector('.hero-subtext')?.remove();
  }

  const modal = document.getElementById('vsl-modal') as HTMLElement;
  const modalClose = document.getElementById('vsl-modal-close') as HTMLElement;
  const modalForm = document.getElementById('vsl-modal-form') as HTMLFormElement;

  function openModal() {
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
  }

  // Gate playback behind subscription
  player.on('play', () => {
    console.log('[DA] Play triggered, subscribed:', sessionStorage.getItem('da_subscribed'));
    if (!sessionStorage.getItem('da_subscribed')) {
      player.pause();
      openModal();
    }
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Track which popup CTA triggered the booking
  document.querySelectorAll('#vsl-cta-lock a, #vsl-book-call-gate a').forEach(el => {
    el.addEventListener('click', () => sessionStorage.setItem('da_cta_popup', '1st'));
  });
  document.querySelectorAll('#vsl-popup-2 a.vsl-cta-lock-btn, #vsl-inline-gate-2 a.vsl-cta-lock-btn').forEach(el => {
    el.addEventListener('click', () => sessionStorage.setItem('da_cta_popup', '2nd'));
  });
  document.querySelectorAll('#vsl-popup-3 a.vsl-cta-lock-btn, #vsl-inline-gate-3 a.vsl-cta-lock-btn').forEach(el => {
    el.addEventListener('click', () => sessionStorage.setItem('da_cta_popup', '3rd'));
  });

  // Popup refs
  const ctaLock = document.getElementById('vsl-cta-lock') as HTMLElement;
  const ctaLockClose = document.getElementById('vsl-cta-lock-close') as HTMLElement;
  const popup2 = document.getElementById('vsl-popup-2') as HTMLElement;
  const popup2Close = document.getElementById('vsl-popup-2-close') as HTMLElement;
  const popup3 = document.getElementById('vsl-popup-3') as HTMLElement;
  const popup3Close = document.getElementById('vsl-popup-3-close') as HTMLElement;

  // Inline gate refs
  const inlineGate1 = document.getElementById('vsl-book-call-gate') as HTMLElement;
  const inlineGate2 = document.getElementById('vsl-inline-gate-2') as HTMLElement;
  const inlineGate3 = document.getElementById('vsl-inline-gate-3') as HTMLElement;

  function hideAllInlineGates() {
    [inlineGate1, inlineGate2, inlineGate3].forEach(g => { if (g) g.style.display = 'none'; });
  }

  let ctaShown = false;
  let popup2Shown = false;
  let videoEndTriggered = false;

  player.on('timeupdate', () => {
    const t = player.currentTime;

  const vslWrapper = document.querySelector('.vsl-wrapper') as HTMLElement;
  const scrollToVSL = () => vslWrapper?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    if (!ctaShown && t >= 44) {
      ctaShown = true;
      ctaLock.style.display = 'block';
      document.body.classList.add('page-dimmed');
      setTimeout(scrollToVSL, 100);
    }

    if (!popup2Shown && t >= 212) {
      popup2Shown = true;
      ctaLock.style.display = 'none';
      popup2.style.display = 'flex';
      document.body.classList.add('page-dimmed');
      setTimeout(scrollToVSL, 100);
    }

    if (!videoEndTriggered && t >= 486) {
      videoEndTriggered = true;
      ctaLock.style.display = 'none';
      popup2.style.display = 'none';
      player.pause();
      player.currentTime = 486;
      popup3.style.display = 'block';
      document.body.classList.add('page-dimmed');
      setTimeout(scrollToVSL, 100);
    }
  });

  ctaLockClose.addEventListener('click', () => {
    document.body.classList.remove('page-dimmed');
    ctaLock.style.display = 'none';
    const inlineGate = document.getElementById('vsl-inline-gate') as HTMLElement;
    if (inlineGate) inlineGate.style.display = 'none';
    hideAllInlineGates();
    inlineGate1.style.display = 'block';
    setTimeout(scrollToVSL, 100);
  });

  popup2Close.addEventListener('click', () => {
    document.body.classList.remove('page-dimmed');
    popup2.style.display = 'none';
    hideAllInlineGates();
    inlineGate2.style.display = 'block';
    setTimeout(scrollToVSL, 100);
  });

  popup3Close.addEventListener('click', () => {
    document.body.classList.remove('page-dimmed');
    popup3.style.display = 'none';
    hideAllInlineGates();
    inlineGate3.style.display = 'block';
    setTimeout(scrollToVSL, 100);
  });


  function isValidLebanesePhone(raw: string): boolean {
    let d = raw.replace(/[\s\-()+.]/g, '');
    if (d.startsWith('00961')) d = d.slice(5);
    else if (d.startsWith('961') && d.length >= 10) d = d.slice(3);
    if (d.startsWith('0')) d = d.slice(1);
    return /^\d{7,8}$/.test(d);
  }

  // ── Inline form: subscribe & play without modal ──
  const inlineForm = document.getElementById('vsl-inline-form') as HTMLFormElement;

  inlineForm?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    const nameVal  = (this.querySelector('[name="FIRSTNAME"]') as HTMLInputElement)?.value ?? '';
    const emailVal = (this.querySelector('[name="EMAIL"]') as HTMLInputElement)?.value ?? '';
    const smsVal   = (this.querySelector('[name="SMS"]') as HTMLInputElement)?.value ?? '';
    const phoneErrEl = document.getElementById('vsl-inline-phone-err') as HTMLElement;

    if (!isValidLebanesePhone(smsVal)) {
      if (phoneErrEl) phoneErrEl.style.display = 'block';
      return;
    }
    if (phoneErrEl) phoneErrEl.style.display = 'none';

    btn.disabled = true;
    btn.textContent = 'Subscribing...';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: nameVal, email: emailVal, phone: smsVal, list: 'vsl', ...getTrackingData() }),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error);

      sessionStorage.setItem('da_subscribed', '1');
      sessionStorage.setItem('userData', JSON.stringify({ name: nameVal, email: emailVal, phone: smsVal }));
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'subscription_success_inline' });
      document.getElementById('vsl-inline-gate')?.remove();
      document.querySelector('.hero-subtext')?.remove();
      scrollToVSL();
      player.play();
    } catch {
      btn.disabled = false;
      btn.textContent = 'Unlock My Free Guide';
    }
  });

  modalForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    console.log('[DA] Form submitted');
    const btn = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    const successEl = document.getElementById('vsl-success-msg') as HTMLElement;
    const errorEl = document.getElementById('vsl-error-msg') as HTMLElement;
    const firstnameVal = (this.querySelector('[name="FIRSTNAME"]') as HTMLInputElement)?.value ?? '';
    const emailVal = (this.querySelector('[name="EMAIL"]') as HTMLInputElement)?.value ?? '';
    const smsVal = (this.querySelector('[name="SMS"]') as HTMLInputElement)?.value ?? '';

    if (!isValidLebanesePhone(smsVal)) {
      errorEl.style.display = 'block';
      errorEl.textContent = 'Please enter a valid Lebanese number (e.g. 70 123 456)';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Subscribing...';
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: firstnameVal, email: emailVal, phone: smsVal, list: 'vsl', ...getTrackingData() }),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error);

      sessionStorage.setItem('da_subscribed', '1');
      sessionStorage.setItem('userData', JSON.stringify({ name: firstnameVal, email: emailVal, phone: smsVal }));
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'subscription_success_popup' });
      successEl.style.display = 'block';
      btn.textContent = 'Starting video...';
      document.querySelector('.hero-subtext')?.remove();
      closeModal();
      player.play();
    } catch {
      btn.disabled = false;
      btn.textContent = 'Unlock the FREE tutorial!';
      errorEl.style.display = 'block';
    }
  });
</script>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
