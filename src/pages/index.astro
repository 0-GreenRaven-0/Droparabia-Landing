---
import Layout from '../layouts/Layout.astro';
import { siInstagram, siThreads, siYoutube } from 'simple-icons';
---

<Layout>

  <!-- NEW HERO -->
  <section class="hero-new bg">
    <div class="tp-container">

      <!-- HERO BRAND -->
      <div class="hero-brand-bar">
        <div class="hero-brand-row">
          <img src="/Droparabia.png" alt="Droparabia" class="hero-brand-img" />
          <span class="hero-brand-name">Droparabia</span>
        </div>
        <p class="hero-brand-tagline">Lebanon's 1st Dropshipping Platform!</p>
      </div>

      <h1 class="hero-new-headline">Launch a <span class="h1-underline">high-earning</span></span> online store in less than <span class="h1-simple-underline">30 days</span>!</h1>

      <p class="hero-new-sub">Used by <strong>+600 Lebanese</strong> to sell online <strong>without a huge capital</strong> or owning and managing Inventory</p>

      <div class="cta-block">
        <a href="/survey" class="cta-btn" id="cta1">
          <span class="cta-btn-main">Start selling with Droparabia!</span>
          <span class="cta-btn-sub">See if Droparabia's the right fit for you!</span>
        </a>
        <div class="tp-row">
          <div class="auth-stat">
            <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="tp-logo" />
            <span class="tp-stars-row">
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
              <span class="tp-star tp-star-empty">★</span>
            </span>
          </div>
          <span class="tp-divider"></span>
          <div class="auth-stat auth-stat-row">
            <img src="/MBG.png" alt="Money Back Guarantee" class="badge-mbg-img" />
            <span class="badge-mbg-text">90 Days Money Back Guarantee<br/><span>If you don't get any results after using our system</span></span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <section class="who-section">
    <div class="tp-container">
      <p class="who-intro">This is for every Lebanese who is...</p>
      <ul class="who-list">
        <li>A 9 to 5 worker who wants to start an online business to increase their monthly income</li>
        <li>A university student who'd like to start his own hustle</li>
        <li>A mother who'd love to run a business of her own from home</li>
        <li>Or simply anyone who wants to start dropshipping and later scale to full e-com store</li>
      </ul>
      <p class="who-outro">Does that sound like you?</p>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="carousel-section carousel-section--before-about">
    <h2 class="carousel-heading">
      These people started just like you! <span class="carousel-heading-emoji">👇</span>
    </h2>
    <div class="carousel-container">
      <button class="swiper-button-prev" aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <button class="swiper-button-next" aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
      <div class="swiper testimonials-swiper">
        <div class="swiper-wrapper">
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Case%20Studies/4.png?tr=w-1400,q-100,f-webp" alt="Case Study" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Case%20Studies/5.png?tr=w-1400,q-100,f-webp" alt="Case Study" loading="lazy" /></div>
