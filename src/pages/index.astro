---
import Layout from '../layouts/Layout.astro';
import { siInstagram, siThreads, siYoutube } from 'simple-icons';
---

<Layout>

  <!-- HEADER -->
  <header class="site-header">

  </header>

  <!-- HERO -->
  <section class="hero bg">
    <div class="container">

      <!-- ATTENTION BAR -->
      <div class="attention-bar">
        <span class="attention-bar-label">Free Video Tutorial</span>
        <span class="attention-bar-text">A step-by-step tutorial breaking down a proven system that helped <strong>+500 Lebanese</strong> build a successful online store</span>
      </div>

      <h1>
        How to launch a <span class="h1-highlight">Successful &amp; <span class="h1-underline">high-earning</span></span> online store In <span class="h1-highlight">Lebanon</span>
<span class="h1-sub">A great and proven system which any Lebanese beginner can use to start selling online with a small capital without owning warehouses</span>
      </h1>
      <!-- VSL Video -->
      <div class="vsl-wrapper">
        <video id="vsl-player" playsinline>
          <source src="/vsl.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- CTA LOCK (appears below VSL after 44s) -->
      <div id="vsl-cta-lock" class="vsl-cta-lock" style="display:none">
        <button id="vsl-cta-lock-close" class="vsl-cta-lock-close" aria-label="Close">&times;</button>
        <a href="https://calendly.com/d/cr37-8xm-k5s/45-min-lead-advisory-call" target="_blank" rel="noopener" class="vsl-cta-lock-btn">
          Click Here to Book a Free Call with our team
        </a>
        <div class="vsl-cta-tp-badge">
          <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="vsl-cta-tp-img" />
          <div class="vsl-cta-tp-rating">
            <span class="vsl-cta-tp-great">Great!</span>
            <div class="vsl-cta-tp-stars">
              <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
              <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
              <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
              <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
            </div>
          </div>
        </div>
        <p class="vsl-cta-lock-note">Only 10 spots are available each week to make sure we're helping everyone efficiently getting started</p>
      </div>


      <!-- BOOK A CALL GATE (shown after CTA lock is dismissed) -->
      <div id="vsl-book-call-gate" class="vsl-book-call-gate" style="display:none">
        <div class="vsl-gate-divider">
          <span class="vsl-gate-or">Ready to build your own business?</span>
        </div>
        <div class="vsl-book-call-content">
          <a href="https://calendly.com/d/cr37-8xm-k5s/45-min-lead-advisory-call" target="_blank" rel="noopener" class="vsl-cta-lock-btn">
            Click Here to Book a Free Call with our team
          </a>
          <div class="vsl-cta-tp-badge">
            <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="vsl-cta-tp-img" />
            <div class="vsl-cta-tp-rating">
              <span class="vsl-cta-tp-great">Great!</span>
              <div class="vsl-cta-tp-stars">
                <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
                <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
                <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
                <span class="tp-star-box"><svg viewBox="0 0 24 24"><path fill="#fff" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg></span>
              </div>
            </div>
          </div>
          <p class="vsl-cta-lock-note">Only 10 spots are available each week to make sure we're helping everyone efficiently getting started</p>
        </div>
      </div>

      <!-- INLINE SUBSCRIBE FORM -->
      <div class="vsl-inline-gate" id="vsl-inline-gate">
        <div class="vsl-gate-divider">
          <span class="vsl-gate-or">
            Subscribe to watch the Free Tutorial
          </span>
        </div>
        <div id="vsl-inline-success" class="brevo-alert brevo-alert--success" style="display:none">You're in! Scroll up to watch the video.</div>
        <form id="vsl-inline-form" class="vsl-inline-form" method="POST" action="https://1c3c2cfb.sibforms.com/serve/MUIFAPxMXGELK2J9d0Xxt3PwFRUjxtJZk3Qry8euC5hSvSAPkpZ5LwbXq06mSFZBI-LU2EsYia4abUYDywf846KcddyPIkRgIFLUpa3_CyPYrdcOpuqUjIFu9NxywX-BK3vSvfZ91Wbu_AqEdPe41syClQfRlwdi0VA6Qv-l0kWohS7W5HfLAD_dBWKErnr8MpmZrbTofjCmMm-oXA==" data-type="subscription">
          <div class="vsl-inline-fields">
            <div class="field-line">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </span>
              <input type="text" name="FIRSTNAME" placeholder="First and Last Name" required autocomplete="name" />
            </div>
            <div class="field-line">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              <input type="text" name="EMAIL" placeholder="Your Best Email" required autocomplete="email" />
            </div>
            <div class="field-line">
              <span class="field-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.31 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.45 5.45l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <input type="hidden" name="SMS__COUNTRY_CODE" value="+961" />
              <span class="sms-country-fixed">+961</span>
              <span class="sms-divider">|</span>
              <input type="tel" name="SMS" placeholder="WhatsApp Number" required autocomplete="tel" />
            </div>
            <button type="submit" class="btn-primary vsl-inline-btn">Unlock My Free Guide</button>
          </div>
          <input type="text" name="email_address_check" value="" style="display:none">
          <input type="hidden" name="locale" value="en">
        </form>
      </div>

    </div>
  </section>





  <!-- TESTIMONIALS CAROUSEL -->
  <section class="carousel-section">
    <h2 class="carousel-heading">
      Weekly Wins shared by over <span class="carousel-brand">+500 User</span></h2>
    <div style="text-align:center;margin-bottom:20px;">
      <a href="/testimonials" class="view-all-case-studies">Click to see more case studies &rarr;</a>
    </div>
    <div class="carousel-container">
      <button class="swiper-button-prev" aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <button class="swiper-button-next" aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
      <div class="swiper testimonials-swiper">
        <div class="swiper-wrapper">
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo.png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(1).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(2)%20(1)%20(1).png" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(3).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(4)%20(1).png" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(5).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(6).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(7)%20(1)%20(1).png" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(8).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(9)%20(2).png?updatedAt=1775387951020" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(10).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(11).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(12).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(13).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(14).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(15).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(16).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(17).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(18).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
        </div>
      </div>
    </div>
  </section>

