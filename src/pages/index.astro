  /* ─── FOOTER ─── */
  .footer {
    background: var(--gray-900);
    padding: 48px 24px 0;
  }

  .footer-inner {
    max-width: 1040px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
