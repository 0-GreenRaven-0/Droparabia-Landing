    position: relative;
    box-shadow: 0 24px 80px rgba(0,0,0,0.35);
    transform: translateY(14px) scale(0.97);
    transition: transform 0.25s;
    overflow: hidden;
    box-sizing: border-box;
  }

  .vsl-modal-overlay.is-open .vsl-modal-box {
    transform: translateY(0) scale(1);
  }

  .vsl-modal-close {
    position: absolute;
    top: 14px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: var(--gray-100);
    color: var(--gray-500);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }

  .vsl-modal-close:hover { background: var(--gray-200); color: var(--gray-900); }

  .vsl-modal-head {
    text-align: center;
    margin-bottom: 24px;
  }

  .vsl-modal-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .vsl-modal-logo {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    object-fit: contain;
  }

  .vsl-modal-brand-name {
    font-family: var(--font-brand);
    font-size: 2.5rem;
    color: var(--gray-900);
  }

  .vsl-modal-title {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--gray-900);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .vsl-form-note {
    font-size: 0.8125rem;
    color: black;
    line-height: 1.5;
    text-align: center;
    margin: -4px 0 0;
  }

  @media (max-width: 480px) {
    .vsl-wrapper { border-radius: 12px; box-shadow: 0 0 0 3px #2563eb, 0 12px 32px rgba(37,99,235,0.18); margin: 0 16px 12px; }
    .vsl-modal-box { padding: 32px 20px 24px; }
    .vsl-modal-title { font-size: 1.25rem; }
  }


  .view-all-case-studies {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--blue);
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    transition: border-color 0.15s;
  }

  .view-all-case-studies:hover { border-color: var(--blue); }

  /* ─── CAROUSEL ─── */
  .carousel-section {
    padding: 20px 0 24px;
    background: transparent;
    border-top: none;
  }

  .carousel-heading {
    text-align: center;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 800;
    color: var(--gray-900);
    letter-spacing: -0.025em;
    margin-bottom: 6px;
    text-decoration: none;
  }

  .carousel-heading {
    position: relative;
  }

  .carousel-arrow-svg {
    position: absolute;
    width: 32px;
    height: 44px;
    top: 50%;
    transform: translateY(-50%);
    filter: drop-shadow(0 2px 6px rgba(37,99,235,0.5));
  }

  .carousel-arrow-svg--left { left: 5%; }
  .carousel-arrow-svg--right { right: 5%; }
  @media (min-width: 769px) { .carousel-arrow-svg { display: none; } }

  .carousel-brand {
    font-family: var(--font-brand);
    font-size: 1.45em;
    color: var(--gray-900);
    font-weight: normal;
    vertical-align: middle;
  }

  .carousel-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 76px;
    position: relative;
  }

  .testimonials-swiper {
    padding-bottom: 0;
  }

  .testimonials-swiper .swiper-slide {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .testimonials-swiper .swiper-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  .carousel-container .swiper-button-prev,
  .carousel-container .swiper-button-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    background: var(--blue);
    color: #fff;
    border-radius: 50%;
    border: none;
    outline: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
  }

  .carousel-container .swiper-button-prev { left: 4px; }
  .carousel-container .swiper-button-next { right: 4px; }

  .carousel-container .swiper-button-prev::after,
  .carousel-container .swiper-button-next::after {
    display: none;
  }

  .carousel-container .swiper-button-prev svg,
  .carousel-container .swiper-button-next svg {
    width: 26px;
    height: 26px;
    display: block;
  }

  .testimonials-swiper .swiper-pagination-bullet {
    background: var(--gray-300);
    opacity: 1;
  }

  .testimonials-swiper .swiper-pagination-bullet-active {
    background: var(--blue);
  }

  /* ─── CTA SECTION ─── */
  .tp-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .cta-section {
    padding: 80px 0;
    text-align: center;
  }

  .cta-heading {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    color: var(--gray-900);
    letter-spacing: -0.025em;
    margin-bottom: 12px;
  }

  /* ─── CTA FINAL — light card ─── */
  .cta-section.cta-final {
    background: #e0e0e0;
    padding: 80px 24px;
    text-align: center;
  }

  .cta-section.cta-final .tp-container {
    background: #ffffff;
    border-radius: 28px;
    padding: 64px 64px 56px;
    max-width: 700px;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 24px 80px rgba(0,0,0,0.10),
      0 0 0 1px rgba(0,0,0,0.06);
  }

  /* Subtle blue radial glow */
  .cta-section.cta-final .tp-container::before {
    content: '';
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 520px;
    height: 240px;
    background: radial-gradient(ellipse, rgba(37,99,235,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Thin blue accent bar at top edge */
  .cta-section.cta-final .tp-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 72px;
    height: 3px;
    background: #2563eb;
    border-radius: 0 0 4px 4px;
  }

  /* Brand row */
  .cta-brand-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  .cta-brand-img {
    width: 44px;
    height: 44px;
    border-radius: 11px;
    object-fit: contain;
  }

  .cta-brand-name {
    font-family: var(--font-brand);
    font-size: 1.5rem;
    color: var(--gray-900);
    letter-spacing: -0.01em;
  }

  .cta-section.cta-final .cta-heading--large {
    font-family: var(--font-brand);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: normal;
    color: var(--gray-900);
    max-width: 520px;
    margin: 0 auto 16px;
    letter-spacing: -0.02em;
    line-height: 1.2;
    position: relative;
  }

  .cta-section.cta-final .cta-sub--large {
    font-size: 1rem;
    color: var(--gray-500);
    max-width: 460px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  /* Pills row */
  .cta-section.cta-final .cta-bullets {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin: 0 auto 48px;
    text-align: center;
    position: relative;
  }

  .cta-section.cta-final .cta-bullets li {
    background: var(--blue-light);
    border: 1px solid var(--blue-border);
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--blue);
    list-style: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .cta-section.cta-final .cta-bullets li:hover {
    background: var(--blue-mid);
    border-color: var(--blue-border);
  }

  /* Button — pulsing glow */
  .btn-book-call {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    background: var(--blue);
    color: var(--white);
    font-size: 1.0625rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.02em;
    box-shadow: var(--shadow-blue);
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    position: relative;
  }

  .btn-book-call:hover {
    background: var(--blue-hover);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(37,99,235,0.4);
    color: var(--white);
  }

  .btn-book-call--large {
    font-size: 1.125rem;
    padding: 18px 52px;
    animation: cta-pulse 2.8s ease-in-out infinite;
  }

  @keyframes cta-pulse {
    0%, 100% { box-shadow: 0 8px 32px rgba(37,99,235,0.3); }
    50%       { box-shadow: 0 8px 48px rgba(37,99,235,0.6), 0 0 0 6px rgba(37,99,235,0.08); }
  }

  /* Scarcity — light-mode variant inside card */
  .cta-section.cta-final .cta-scarcity {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #dc2626;
    display: block;
    width: fit-content;
    margin: 20px auto 0;
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 6px 16px;
    position: relative;
  }

  @media (max-width: 768px) {
    .cta-section.cta-final .tp-container { padding: 52px 36px 48px; }
  }

  @media (max-width: 480px) {
    .cta-section.cta-final .tp-container { padding: 44px 24px 40px; border-radius: 20px; }
    .cta-section.cta-final .cta-bullets { flex-direction: column; align-items: center; }
  }

  /* ─── VSL POPUP ─── */
  /* ─── PAGE DIM OVERLAY ─── */
  .page-dim-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.78);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s, visibility 0.35s;
  }

  body.page-dimmed .page-dim-overlay {
    opacity: 1;
    visibility: visible;
  }

  body.page-dimmed .vsl-wrapper {
    position: relative;
    z-index: 102;
  }

  /* ─── VSL CTA LOCK ─── */
  .vsl-cta-lock {
    position: relative;
    z-index: 102;
    background: #fff;
    border-radius: 14px;
    padding: 44px 24px 20px;
    max-width: 620px;
    margin: 12px auto 0;
    text-align: center;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    animation: cta-lock-in 0.3s ease both;
  }

  @keyframes cta-lock-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .vsl-cta-lock-close {
    position: absolute;
    top: 10px;
    right: 12px;
    background: var(--gray-100);
    border: 1px solid var(--gray-300);
    font-size: 1.125rem;
    line-height: 1;
    color: var(--gray-700);
    cursor: pointer;
    padding: 3px 8px;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    font-weight: 600;
  }

  .vsl-cta-lock-close:hover { background: var(--gray-200); color: var(--gray-900); }

  .vsl-cta-lock-btn {
    display: block;
    background: #16a34a;
    color: #fff;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 14px 24px;
    border-radius: 8px;
    text-decoration: none;
    margin-bottom: 14px;
    box-shadow: 0 4px 16px rgba(22,163,74,0.3);
    transition: background 0.15s;
    animation: cta-shake 2s ease-in-out infinite;
  }

  .vsl-cta-lock-btn:hover { background: #15803d; }

  .vsl-cta-tp-badge {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .vsl-cta-tp-rating {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .vsl-cta-tp-great {
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--gray-900);
  }

  .vsl-cta-tp-stars {
    display: flex;
    gap: 4px;
  }

  .tp-star {
    display: inline-block;
    width: 28px;
    height: 28px;
    fill: #00b67a;
    flex-shrink: 0;
  }

  .tp-star-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #00b67a;
    flex-shrink: 0;
  }

  .tp-star-box svg {
    display: block;
    width: 16px;
    height: 16px;
  }

  .vsl-cta-tp-img {
    height: 44px;
    width: auto;
    display: block;
  }

  .vsl-cta-lock-note {
    font-size: 0.8125rem;
    color: var(--gray-900);
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .guarantee-block {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 5px;
    margin-top: 8px;
    text-align: left;
  }

  .guarantee-img {
    width: 100px;
    flex-shrink: 0;
  }

  .guarantee-headline {
    font-family: var(--font-brand);
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    font-weight: bold;
    color: var(--gray-900);
    line-height: 1.2;
  }

  .guarantee-sub {
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    color: var(--gray-600);
    line-height: 1.4;
  }

  .popup-heading {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--gray-900);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .popup-body {
    font-size: 0.9375rem;
    color: var(--gray-700);
    font-weight: 500;
    line-height: 1.55;
    margin-bottom: 16px;
  }

  .popup-brand-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .popup-brand-logo {
    height: 68px;
    width: auto;
  }

  .popup-brand-name {
    font-family: 'IBrand', sans-serif;
    font-size: 2.25rem;
    font-weight: 400;
    color: var(--gray-900);
  }

  .popup-platform-tag {
    font-size: 0.875rem;
    color: var(--gray-600);
    font-weight: 600;
  }

  .popup-users-count {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 10px;
  }

  .popup-brand-highlight {
    font-size: 1.3rem;
    font-weight: 800;
    color: #1d4ed8;
    margin: 6px 0 10px;
  }

  .popup-cta-text {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 14px;
    line-height: 1.4;
  }

  .btn-subtext {
    display: block;
    font-size: 0.75rem;
    font-weight: 400;
    opacity: 0.75;
    margin-top: 3px;
  }
  .popup-subtext {
    font-size: 0.8125rem;
    color: var(--gray-600);
    font-weight: 500;
    margin-top: 8px;
    line-height: 1.5;
  }

  /* My own css */
  .popup-gate-heading {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--gray-900);
    margin-bottom: 14px;
    line-height: 1.3;
    text-align: center;
  }

  .vsl-cta-lock h2 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--gray-900);
    margin-bottom: 14px;
    line-height: 1.3;
    text-align: center;
  }

  .john-body {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gray-700);
    line-height: 1.55;
    margin-bottom: 14px;
  }

  .john-re {
    width: 100%;
    border-radius: 8px;
    display: block;
    margin-top: 14px;
  }
  /* ---------- */

  /* ─── RESPONSIVE ─── */
  /* ─── TABLET (max 768px) ─── */
  @media (max-width: 768px) {
    .bg { background-size: 180px 180px; }
    .hero { min-height: unset; padding: 80px 0 4px; }
    .vsl-wrapper { margin: 0 24px 4px; }
    .brand-img { height: 64px; }
    .brand-name-black { font-size: 2rem; }
    .brand-logo-inline { gap: 8px; }

    .hero-sub { gap: 16px; }
    .hero-sub li { font-size: 0.9375rem; }

    .form-card { padding: 28px 32px; }

  }

  /* ─── TABLET CTA LOCK ─── */
  @media (max-width: 768px) {
    .vsl-cta-lock { margin: 8px 24px 0; }
  }

  /* ─── TABLET ONLY (481px – 768px) ─── */
  @media (min-width: 481px) and (max-width: 768px) {
    .hero { padding-top: 80px; }
    .vsl-wrapper { margin-left: auto; margin-right: auto; margin-bottom: 8px; }
    .container { display: flex; flex-direction: column; }
    .attention-bar { order: 0; }
    h1 { order: 1; }
    .hero-subtext { order: 2; font-size: 1.2rem !important; padding-top: 12px; }
    .vsl-wrapper { order: 3; margin-bottom: 8px; }
    .vsl-cta-lock { order: 4; margin: 8px 20px 0; padding: 40px 20px 16px; }
    #vsl-popup-2 { order: 4; }
    #vsl-popup-3 { order: 4; }
    .vsl-book-call-gate { order: 5; }
    #vsl-inline-gate-2 { order: 5; }
    #vsl-inline-gate-3 { order: 5; }
    .carousel-section { order: 6; padding-top: 40px; }
    .carousel-heading { padding: 0 64px; margin-bottom: 36px !important; }
    .carousel-arrow-svg { width: 32px; height: 42px; }
    .carousel-arrow-svg--left { left: 18%; }
    .carousel-arrow-svg--right { right: 18%; }
    .attention-bar-text { font-weight: 700 !important; }
    .popup-brand-logo { height: 56px; }
    .popup-brand-name { font-size: 1.9rem; }
    .popup-platform-tag { font-size: 0.8rem; }
    .vsl-cta-lock-btn { font-size: 1rem; padding: 12px 18px; }
    .john-re { max-width: 420px; margin-left: auto; margin-right: auto; }
  }

  /* ─── MOBILE (max 480px) ─── */
  @media (max-width: 480px) {
    .bg { background-image: none; }
    .hero { min-height: unset; padding: 12px 0 16px; }
    .container { display: flex; flex-direction: column; }
    .attention-bar { order: 0; }
    h1 { order: 1; }
    .hero-subtext { order: 2; }
    .vsl-wrapper { order: 3; }
    .vsl-cta-lock { order: 4; }
    #vsl-popup-2 { order: 4; }
    #vsl-popup-3 { order: 4; }
    .vsl-book-call-gate { order: 5; }
    #vsl-inline-gate-2 { order: 5; }
    #vsl-inline-gate-3 { order: 5; }
    .carousel-section { order: 6; }
    .brand-img { height: 76px; }
    .brand-name-black { font-size: 2.125rem; }
    .brand-logo-inline { gap: 6px; margin-bottom: 6px; }
    h1 { font-size: 1.9rem; max-width: 100%; }
    .h1-sub { font-size: 1rem; margin-top: 4px; padding-bottom: 16px; }
    .attention-bar { gap: 6px; }
    .attention-bar-label { font-size: 0.9rem !important; font-weight: 400 !important; padding: 6px 14px !important; }
    .attention-bar-text { font-size: 0.75rem; width: 85%; font-weight: 600 !important; }
    .hero-subtext { font-size: 0.8rem; padding-bottom: 6px; padding-left: 20px; padding-right: 20px; }
    .subtext-mobile-hide { display: none; }
    .vsl-wrapper { margin-bottom: 0 !important; }

    .hero-sub {
      flex-direction: column;
      align-items: center;
      gap: 10px;
      padding: 0 8px;
    }
    .hero-sub li { font-size: 0.9375rem; }

    .form-card { padding: 24px 20px; }
    .bonuses-heading { font-size: 1rem; }
    .bonus-text { font-size: 0.875rem; }
    /* Headline — more width */
    h1 { padding: 0 8px; }

    .carousel-section { padding: 16px 0 24px; }
    .carousel-heading { font-size: 1.1rem; }
    .form-section { padding: 8px 0 32px; }
    .carousel-heading { padding: 0 48px; margin-bottom: 24px; }

    .carousel-container { padding: 0 52px; }
    .carousel-container .swiper-button-prev,
    .carousel-container .swiper-button-next { width: 36px; height: 36px; }
    .carousel-container .swiper-button-prev { left: 4px; }
    .carousel-container .swiper-button-next { right: 4px; }
    .carousel-container .swiper-button-prev svg,
    .carousel-container .swiper-button-next svg { width: 18px; height: 18px; }

    .footer-inner { flex-direction: column; gap: 32px; }
    .footer-brand { max-width: 100%; }

    .vsl-cta-lock { margin: 16px 16px 0; padding: 36px 14px 12px; border-radius: 10px; }
    .vsl-cta-lock h2 { display: block; }
    .vsl-cta-lock-btn { font-size: 0.9rem; padding: 9px 12px; margin-bottom: 8px; }
    .vsl-cta-tp-badge { flex-direction: column; gap: 4px; margin-bottom: 8px; }
    .tp-star { width: 22px; height: 22px; }
    .vsl-cta-tp-img { height: 28px; }
    .tp-star-box { width: 18px; height: 18px; }
    .tp-star-box svg { width: 10px; height: 10px; }
