---
import Layout from '../layouts/Layout.astro';
import { siInstagram, siThreads, siYoutube } from 'simple-icons';
---

<Layout>
  <link slot="head" rel="preload" as="video" href="/vsl.mp4" type="video/mp4" />

  <!-- HEADER -->
  <header class="site-header">

  </header>

  <!-- HERO -->
  <section class="hero bg">
    <div class="container">

      <!-- ATTENTION BAR -->
      <div class="attention-bar">
        <span class="attention-bar-label" style="display:flex;align-items:center;gap:8px;font-family:'IBrand',sans-serif;"><span style="font-size:0.75rem;">brought to you by</span> <img src="/Droparabia.png" alt="Droparabia" style="height:44px;vertical-align:middle;" /> <span style="font-size:1.6rem;">Droparabia</span></span>
        <span class="attention-bar-text">Strategy used by successful e-com brands in Lebanon that cuts inventory costs</span>
      </div>

      <h1>
        Launch a <span class="h1-highlight">Successful &amp; <span class="h1-underline">High-Earning</span></span> online store in <span class="h1-highlight">Lebanon</span> in just 4 steps!
      </h1>
      <p class="hero-subtext"><span style="font-size:1.2em; font-weight:800; text-decoration:underline; text-decoration-color:#2563eb; text-underline-offset:4px; text-decoration-thickness:1.5px;">Watch this FREE tutorial to learn how to:</span><br>
        <span style="display:inline-block; text-align:left; margin-top:6px; line-height:2;">
          <span style="color:#2563eb;">✔</span> Find &amp; identify a money-making product<br>
          <span style="color:#2563eb;">✔</span> Find a local supplier in Lebanon<br>
          <span style="color:#2563eb;">✔</span> Create your online store<br>
          <span style="color:#2563eb;">✔</span> Run ads to attract customers
        </span>
      </p>
      <!-- VSL Video -->
      <div class="vsl-wrapper">
        <div id="vsl-pre-init" style="position:absolute;inset:0;z-index:5;display:flex;align-items:center;justify-content:center;border-radius:16px;overflow:hidden;">
          <img src="/Group%205.png" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;" alt="" />
          <div style="position:relative;z-index:1;width:120px;height:64px;background:#2563eb;border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,99,235,0.4);">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="white"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
        <video id="vsl-player" playsinline preload="auto" poster="/Group%205.png">
          <source src="/vsl.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- CTA LOCK (appears below VSL after 44s) -->
      <!-- ═══════════════════════════════════════════════════
           POPUP 1  (triggers at 44s)
           INLINE GATE 1  (shown when Popup 1 is dismissed)
           ═══════════════════════════════════════════════════ -->
      <div id="vsl-cta-lock" class="vsl-cta-lock" style="display:none">
        <button id="vsl-cta-lock-close" class="vsl-cta-lock-close" aria-label="Close">&times;</button>
        <h2>You don't have to figure it all by yourself!</h2>
        <a id="cta-book-call-popup" href="/survey" class="vsl-cta-lock-btn">Click Here to Join the Community!<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
        <p class="john-body">Access the same <strong>Proven System</strong> and community support that helped <strong>John</strong> make <strong>his first $11,000!</strong> during the war!</p>
        <img src="https://ik.imagekit.io/greenraven/MJ/Popups/popup%201.png" class="john-re" />
      </div>

      <div id="vsl-book-call-gate" class="vsl-book-call-gate" style="display:none">
        <div class="vsl-book-call-content">
          <h2 class="popup-gate-heading">You don't have to figure it all by yourself!</h2>
          <a id="cta-book-call-gate" href="/survey" class="vsl-cta-lock-btn">Click Here to Join the Community!<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
          <p class="john-body">Access the same <strong>Proven System</strong> and community support that helped <strong>John</strong> make <strong>his first $11,000!</strong> during the war!</p>
          <img src="https://ik.imagekit.io/greenraven/MJ/Popups/popup%201.png" class="john-re" style="margin-top:12px;" />
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════
           POPUP 2  (triggers at 3:32)
           INLINE GATE 2  (shown when Popup 2 is dismissed)
           ═══════════════════════════════════════════════════ -->
      <div id="vsl-popup-2" class="vsl-cta-lock" style="display:none; flex-direction:column; gap:16px;">
        <button id="vsl-popup-2-close" class="vsl-cta-lock-close" aria-label="Close">&times;</button>
        <div class="popup-brand-row">
          <img src="/Droparabia.png" alt="Droparabia" class="popup-brand-logo" />
          <span class="popup-brand-name">Droparabia</span>
        </div>
        <p class="popup-platform-tag">The platform that allowed <strong>+600 Lebanese</strong> build their own high-earning stores <strong>without touching inventories</strong></p>
        <a href="/survey" class="vsl-cta-lock-btn">
          Start your business with Droparabia!<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
   
        <div class="vsl-cta-tp-badge">
          <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="vsl-cta-tp-img" />
          <div class="vsl-cta-tp-stars">
            <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
            <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
            <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
            <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
            <svg viewBox="0 0 24 24" class="tp-star"><path fill="#999" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
          </div>
        </div>
      </div>

      <div id="vsl-inline-gate-2" class="vsl-book-call-gate" style="display:none">
        <div class="vsl-book-call-content">
          <div class="popup-brand-row">
            <img src="/Droparabia.png" alt="Droparabia" class="popup-brand-logo" />
            <span class="popup-brand-name">Droparabia</span>
          </div>
          <p class="popup-platform-tag">The platform that allowed <strong>+600 Lebanese</strong> build their own high-earning stores <strong>without touching inventories</strong></p>
          <a href="/survey" class="vsl-cta-lock-btn">Interested in starting a high-earning business?<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
          <p class="popup-users-count">+600 Active Lebanese seller</p>
          <div class="vsl-cta-tp-badge">
            <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="vsl-cta-tp-img" />
            <div class="vsl-cta-tp-stars">
              <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
              <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
              <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
              <svg viewBox="0 0 24 24" class="tp-star"><path fill="#00b67a" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
              <svg viewBox="0 0 24 24" class="tp-star"><path fill="#999" d="M12 2l2.9 8.9H23l-7.5 5.5 2.9 8.9L12 19.8l-7.5 5.5 2.9-8.9L0 10.9h8.1z"/></svg>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════
           POPUP 3  (triggers at 8:06 / video end)
           INLINE GATE 3  (shown when Popup 3 is dismissed)
           ═══════════════════════════════════════════════════ -->
      <div id="vsl-popup-3" class="vsl-cta-lock" style="display:none">
        <button id="vsl-popup-3-close" class="vsl-cta-lock-close" aria-label="Close">&times;</button>
        <h2>Are you ready to start your own high-earning store from home?</h2>
        <p class="popup-body">And you can get started without experience and without spending a single dollar on inventory</p>

        <a href="/survey" class="vsl-cta-lock-btn">I'm ready to start building my business!<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
      </div>

      <div id="vsl-inline-gate-3" class="vsl-book-call-gate" style="display:none">
        <div class="vsl-book-call-content">
          <h2 class="popup-gate-heading">Are you ready to start your own high-earning store from home?</h2>
          <p class="popup-body">And you can get started without experience and without spending a single dollar on inventory</p>
  
          <a href="/survey" class="vsl-cta-lock-btn">I'm ready to start building my business!<span class="btn-subtext">Book a FREE strategy call with our Team</span></a>
        </div>
      </div>


    </div>
  </section>


  <!-- TESTIMONIALS CAROUSEL -->
  <section class="carousel-section">
    <h2 class="carousel-heading">
      <svg class="carousel-arrow-svg carousel-arrow-svg--left" viewBox="0 0 24 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2 L12 22 M4 15 L12 24 L20 15" stroke="url(#arrowGrad)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="arrowGrad" x1="12" y1="2" x2="12" y2="24" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#1d4ed8"/></linearGradient></defs></svg>
      <span style="font-size:0.85em;">See how it worked for</span> <br/><span style="font-size:1.3em;">+600 Lebanese!</span>
      <svg class="carousel-arrow-svg carousel-arrow-svg--right" viewBox="0 0 24 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2 L12 22 M4 15 L12 24 L20 15" stroke="url(#arrowGrad2)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="arrowGrad2" x1="12" y1="2" x2="12" y2="24" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#1d4ed8"/></linearGradient></defs></svg>
    </h2>
    <div style="display:none;">
      <a href="/testimonials" class="view-all-case-studies">Click to see more case studies &rarr;</a>
    </div>
    <div class="carousel-container">
      <button class="swiper-button-prev" aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <button class="swiper-button-next" aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
