<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  document.querySelectorAll('.testimonials-swiper').forEach((swiperEl) => {
    const container = swiperEl.closest('.carousel-container');
    new Swiper(swiperEl, {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        600: { slidesPerView: 2, spaceBetween: 20 },
        1024: { slidesPerView: 3, spaceBetween: 24 },
      },
      loop: true,
      autoplay: {
        delay: 3500,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: container.querySelector('.swiper-button-next'),
        prevEl: container.querySelector('.swiper-button-prev'),
      },
      pagination: false,
    });
  });
</script>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const summary = item.querySelector('summary');
    if (!summary) return;

    summary.addEventListener('click', (e) => {
      e.preventDefault();

      if (item.open) {
        const anim = item.animate([
          { height: item.offsetHeight + 'px' },
          { height: summary.offsetHeight + 'px' }
        ], { duration: 280, easing: 'ease' });
        item.style.overflow = 'hidden';
        anim.onfinish = () => {
          item.open = false;
          item.style.height = '';
          item.style.overflow = '';
        };
      } else {
        item.open = true;
        const fullHeight = item.offsetHeight;
        item.style.overflow = 'hidden';
        item.animate([
          { height: summary.offsetHeight + 'px' },
          { height: fullHeight + 'px' }
        ], { duration: 280, easing: 'ease' });
        setTimeout(() => { item.style.overflow = ''; }, 280);
      }
    });
  });
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('sib-form');
    if (!form) return;
    var successEl = document.getElementById('success-message');
    var errorEl = document.getElementById('error-message');
    var btn = form.querySelector('button[type="submit"]');
    var btnText = btn.textContent;

    function isValidLebanesePhone(raw) {
      var d = raw.replace(/[\s\-()+.]/g, '');
      if (d.startsWith('00961')) d = d.slice(5);
      else if (d.startsWith('961') && d.length >= 10) d = d.slice(3);
      if (d.startsWith('0')) d = d.slice(1);
      return /^\d{7,8}$/.test(d);
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      successEl.style.display = 'none';
      errorEl.style.display = 'none';

      var nameVal  = form.querySelector('[name="FIRSTNAME"]') ? form.querySelector('[name="FIRSTNAME"]').value : '';
      var emailVal = form.querySelector('[name="EMAIL"]')     ? form.querySelector('[name="EMAIL"]').value     : '';
      var smsVal   = form.querySelector('[name="SMS"]')       ? form.querySelector('[name="SMS"]').value       : '';

      if (!isValidLebanesePhone(smsVal)) {
        errorEl.style.display = 'block';
        errorEl.textContent = 'Please enter a valid Lebanese number (e.g. 70 123 456)';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Submitting...';
      var utmKeys  = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
      var utms     = {};
      utmKeys.forEach(function(k) { var v = sessionStorage.getItem(k); if (v) utms[k] = v; });
      var ref = sessionStorage.getItem('da_referrer') || '';

      fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.assign({ name: nameVal, email: emailVal, phone: smsVal, list: 'vsl', referrer: ref }, utms)),
      })
        .then(function (res) { return res.json(); })
        .then(function (json) {
          if (!json.success) throw new Error(json.error);
          sessionStorage.setItem('da_subscribed', '1');
          sessionStorage.setItem('userData', JSON.stringify({ name: nameVal, email: emailVal, phone: smsVal }));
          successEl.style.display = 'block';
          btn.textContent = 'Subscribed!';
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = btnText;
          errorEl.style.display = 'block';
        });
    });
  });
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var overlay = document.getElementById('cta-popup-overlay');
    var closeBtn = document.getElementById('cta-popup-close');
    var ctaBtn = document.getElementById('cta-popup-btn');
    if (!overlay) return;

    function closePopup() {
      overlay.classList.remove('is-open');
    }

    var POPUP_ENABLED = false;
    if (POPUP_ENABLED) {
      setTimeout(function () {
        if (sessionStorage.getItem('da_free_website_popup_shown')) return;
        overlay.classList.add('is-open');
        sessionStorage.setItem('da_free_website_popup_shown', '1');
      }, 6000);
    }

    closeBtn.addEventListener('click', closePopup);
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closePopup();
    });
    ctaBtn.addEventListener('click', function () {
      sessionStorage.setItem('da_cta_popup', 'free_website_6s');
    });
  });
</script>
