---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- HEADER -->
  <header class="site-header">

  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Learn how to use</p>
      <h1>
        <span class="brand-logo-inline">
          <img src="/Droparabia.png" alt="Droparabia logo" class="brand-img" />
          <span class="brand-name-black">Droparabia</span>
        </span>
        <br />
        The 1st Dropshipping Platform in Lebanon that allowed
        <span class="accent">+400 Lebanese</span> to start a profitable online business
        in just <span class="accent">10–14 days!</span>
      </h1>
      <ul class="hero-sub">
        <li>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="#2563eb"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          No Huge Upfront Costs
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="#2563eb"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          No Risky Chinese Imports
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="12" fill="#2563eb"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          No Warehouses
        </li>
      </ul>
    </div>
  </section>


  <!-- CTA FORM -->
  <section class="form-section">
    <div class="container">
      <div class="form-card">
        <h3 class="form-section-heading">Subscribe to Watch a Free Tutorial</h3>
        <h3 class="bonuses-heading">And Claim these bonuses</h3>

        <div class="bonus-list">
          <div class="bonus-item">
            <div class="bonus-check">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="bonus-text">+20 Hours of free courses and recorded tutorial</div>
          </div>
          <div class="bonus-item">
            <div class="bonus-check">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="bonus-text">
              Access to our <span class="bonus-dropvault">Dropvault</span> <span class="bonus-skool"><span style="color:#3D4DB7">s</span><span style="color:#D94535">k</span><span style="color:#E8A83A">o</span><span style="color:#5BB5E5">o</span><span style="color:#D94535">l</span></span> Community
            </div>
          </div>
          <div class="bonus-item">
            <div class="bonus-check">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div class="bonus-text">Invitation to our WhatsApp channel where we share interesting content</div>
          </div>
        </div>

        <form class="lead-form" action="/watch" method="GET">
          <div class="field-line">
            <span class="field-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <input type="email" name="email" placeholder="Your Best Email" required autocomplete="email" />
          </div>
          <div class="field-line">
            <span class="field-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.31 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.45 5.45l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <input type="tel" name="phone" placeholder="(+961) WhatsApp Number" required autocomplete="tel" />
          </div>
          <button type="submit" class="btn-primary">Watch the Free Tutorial!</button>
        </form>
      </div>
    </div>
  </section>

  <!-- REVIEWS WIDGET -->
  <section class="reviews-section">
    <div class="reviews-widget">

      <div class="reviews-header">
        <a class="tp-logo" href="https://www.trustpilot.com/review/droparabia.com" target="_blank" rel="noopener">
          <svg class="tp-logo-icon" viewBox="0 0 126 126" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="126" height="126" rx="4" fill="#00B67A"/>
            <path d="M63 18l11.8 36.3H113L82.1 75.7l11.8 36.3L63 90.6 32.1 112l11.8-36.3L13 54.3h38.2L63 18z" fill="white"/>
          </svg>
          <span class="tp-logo-text">Trustpilot</span>
        </a>
        <div class="reviews-score">
          <div class="rs-top-row">
            <div class="rs-number">3.9</div>
            <div class="rs-label">Great</div>
          </div>
          <div class="rs-stars" id="header-stars"></div>
        </div>
      </div>

      <div class="reviews-track-wrap">
        <div class="reviews-track" id="reviews-track"></div>

      </div>

      <div class="reviews-footer">
        <a class="reviews-read-all" href="https://www.trustpilot.com/review/droparabia.com" target="_blank" rel="noopener">
          Read all reviews on Trustpilot
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>

    </div>
  </section>



  <!-- TESTIMONIALS CAROUSEL -->
  <section class="carousel-section">
    <h2 class="carousel-heading"><span class="carousel-brand">Droparabia</span>'s Latest Case studies</h2>
    <div class="carousel-container">
      <div class="swiper testimonials-swiper">
        <div class="swiper-wrapper">
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo.png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(1).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(2).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(3).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(4).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(5).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(6).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(7).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(8).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(9).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(10).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(11).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(12).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(13).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(14).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(15).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(16).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(17).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
          <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo%20(18).png?tr=w-700,q-95,f-webp" alt="Testimonial" loading="lazy" /></div>
        </div>
        <div class="swiper-pagination"></div>
        <button class="swiper-button-prev" aria-label="Previous">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <button class="swiper-button-next" aria-label="Next">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-logo">Droparabia</span>
      <p>© 2025 Droparabia. All rights reserved.</p>
    </div>
  </footer>

</Layout>

<style>
  .container {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── HEADER ─── */
  .site-header {
    background: transparent;
    border-bottom: 1px solid var(--gray-200);
    padding: 16px 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
  }

  .logo {
    font-family: var(--font-brand);
    font-size: 1.75rem;
    color: var(--blue);
  }

  /* ─── HERO ─── */
  .hero {
    padding: 22px 0 20px;
    text-align: center;
    background: transparent;
  }

  .brand-inline {
    font-family: var(--font-brand);
    color: var(--blue);
    font-weight: normal;
    font-size: 1.15em;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--blue);
    background: var(--blue-light);
    border: 1px solid var(--blue-border);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.625rem);
    font-weight: 800;
    color: var(--gray-900);
    line-height: 1.25;
    letter-spacing: -0.025em;
    max-width: 960px;
    margin: 0 auto 16px;
  }

  .brand-logo-inline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .brand-img {
    height: 88px;
    width: auto;
  }

  .brand-name-black {
    font-family: var(--font-brand);
    color: var(--gray-900);
    font-size: 2.75rem;
    font-weight: normal;
    line-height: 1;
  }

  .accent {
    color: var(--blue);
  }

  .hero-sub {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
    margin-top: 8px;
  }

  .hero-sub li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--gray-900);
  }

  .hero-sub svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* ─── TRUSTPILOT TOP ─── */
  .trustpilot-top {
    padding: 12px 0;
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
  }

  /* ─── FORM SECTION ─── */
  .form-section {
    padding: 16px 0 40px;
    background: transparent;
  }

  .form-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    max-width: 520px;
    margin: 0 auto;
    padding: 32px 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .bonuses-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .bonus-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .bonus-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .bonus-check {
    width: 24px;
    height: 24px;
    min-width: 24px;
    border-radius: 50%;
    background: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bonus-text {
    font-size: 0.9375rem;
    color: var(--gray-700);
    line-height: 1.55;
    font-weight: 500;
  }

  .bonus-dropvault {
    font-family: var(--font-brand);
    font-size: 1.0625rem;
    color: var(--gray-900);
  }

  .bonus-skool {
    font-weight: 700;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: left;
  }

  .form-section-heading {
    text-align: center;
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.02em;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  .bonuses-heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--gray-900);
    text-align: center;
    margin-bottom: 20px;
  }

  .field-line {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 16px;
    border: 1.5px solid var(--blue);
    border-radius: var(--radius-sm);
    background: var(--white);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .field-line:focus-within {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .field-icon {
    color: var(--gray-500);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .field-line:focus-within .field-icon {
    color: var(--blue);
  }

  .field-line input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 0.9375rem;
    color: var(--gray-900);
    background: transparent;
    font-family: var(--font-body);
  }

  .field-line input::placeholder {
    color: var(--gray-500);
  }

  .btn-primary {
    width: 100%;
    padding: 16px 24px;
    background: var(--blue);
    color: var(--white);
    font-size: 1.0625rem;
    font-weight: 700;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: background 0.15s ease, transform 0.1s ease, box-shadow 0.15s ease;
    box-shadow: var(--shadow-blue);
    margin-top: 24px;
  }

  .btn-primary:hover {
    background: var(--blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 10px 36px rgba(37, 99, 235, 0.28);
  }

  .form-privacy {
    font-size: 0.75rem;
    color: var(--gray-400);
    margin-top: 12px;
  }

  /* ─── TESTIMONIALS ─── */
  .testimonials-section {
    padding: 80px 0;
    background: var(--white);
  }

  .trustpilot-fallback {
    display: block;
    text-align: center;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--gray-700);
    padding: 14px;
    border: 1px dashed var(--gray-300);
    border-radius: var(--radius);
    text-decoration: none;
    margin-bottom: 40px;
  }

  .trustpilot-widget {
    margin-bottom: 40px;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .screenshot-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 56px 20px;
    border: 2px dashed var(--gray-300);
    border-radius: var(--radius-lg);
    background: var(--gray-50);
    text-align: center;
    color: var(--gray-500);
    font-size: 0.9375rem;
    font-weight: 500;
    min-height: 240px;
  }

  .screenshot-placeholder small {
    font-size: 0.75rem;
    color: var(--gray-400);
    font-weight: 400;
  }

  /* ─── FOOTER ─── */
  .footer {
    padding: 28px 0;
    background: var(--gray-900);
    border-top: 1px solid var(--gray-800);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: var(--font-brand);
    color: var(--white);
    font-size: 1.25rem;
  }

  .footer p {
    font-size: 0.8125rem;
    color: var(--gray-500);
  }

  /* ─── REVIEWS WIDGET ─── */
  .reviews-section {
    padding: 72px 0;
    background: transparent;
    border-top: 1px solid var(--gray-200);
  }

  .reviews-widget {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .reviews-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .reviews-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .rs-top-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .rs-number {
    font-size: 1.625rem;
    font-weight: 800;
    color: var(--gray-900);
    line-height: 1;
  }

  .rs-meta {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .rs-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--gray-900);
  }

  .rs-stars {
    display: flex;
    gap: 3px;
  }

  .rs-count {
    font-size: 0.8125rem;
    color: var(--gray-500);
  }

  .tp-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .tp-logo-icon {
    width: 42px;
    height: 42px;
    border-radius: 4px;
  }

  .tp-logo-text {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--gray-900);
    letter-spacing: -0.02em;
  }

  /* Star boxes */
  .r-star {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    flex-shrink: 0;
    line-height: 0;
  }

  .r-star svg {
    display: block;
    flex-shrink: 0;
  }
  .r-star.s5 { background: #00B67A; }
  .r-star.s4 { background: #73CF11; }
  .r-star.s3 { background: #FFCE00; }
  .r-star.s2 { background: #FF8622; }
  .r-star.s1 { background: #FF3722; }
  .r-star.s0 { background: var(--gray-200); }

  /* Track */
  .reviews-track-wrap { position: relative; }

  .reviews-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  .reviews-track::-webkit-scrollbar { display: none; }

  /* Card */
  .r-card {
    flex: 0 0 320px;
    background: var(--white);
    border-radius: var(--radius);
    padding: 20px 24px 16px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .r-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

