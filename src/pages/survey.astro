    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>Get Started — Droparabia</title>
    <link rel="icon" type="image/png" href="/Droparabia.png" />
    <style>
      @font-face { font-family: 'IBrand'; src: url('/fonts/ibrand.otf') format('opentype'); font-weight: normal; font-style: normal; font-display: swap; }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: #F1F5F9; min-height: 100vh; -webkit-font-smoothing: antialiased; }
      .survey-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.25rem 1rem; min-height: 100svh; }
      .survey-card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 1.75rem; width: 100%; max-width: 680px; }
      .survey-title { color: #2563EB; font-size: 0.95rem; font-weight: 700; text-align: center; line-height: 1.5; margin-bottom: 1.25rem; }
      .survey-progress-track { background: #E2E8F0; height: 6px; border-radius: 999px; margin-bottom: 0.5rem; overflow: hidden; }
      .survey-progress-bar { background: linear-gradient(90deg, #2563EB, #3B82F6); height: 100%; border-radius: 999px; transition: width 0.5s ease; }
      .survey-page-count { color: #94A3B8; font-size: 0.9rem; margin-bottom: 1rem; }
      .survey-question { font-size: 1rem; font-weight: 600; color: #374151; margin-bottom: 1rem; line-height: 1.65; }
      .survey-options { display: flex; flex-direction: column; gap: 0.5rem; }
      .survey-inputs { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 0.5rem; }
      .survey-input { padding: 0.75rem 1rem; border-radius: 10px; border: 1.5px solid #E2E8F0; background: #fff; font-size: 0.95rem; font-family: 'Inter', sans-serif; color: #374151; outline: none; transition: border-color 0.15s; width: 100%; }
      .survey-input:focus { border-color: #2563EB; }
      .survey-option { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.9rem; border-radius: 10px; border: 1.5px solid #E2E8F0; background: #fff; cursor: pointer; transition: border-color 0.15s, background 0.15s, transform 0.15s; font-weight: 500; color: #374151; font-size: 0.875rem; width: 100%; text-align: left; }
      .survey-option:hover { border-color: #93C5FD; background: #EFF6FF; transform: translateX(3px); }
      .survey-option.selected { border-color: #2563EB; background: #EFF6FF; box-shadow: 0 2px 8px rgba(37,99,235,0.12); }
      .survey-error { color: #DC2626; font-size: 0.85rem; background: #FEF2F2; border: 1px solid #FCA5A5; border-radius: 8px; padding: 0.5rem 0.75rem; margin-top: 0.75rem; display: none; }
      .survey-nav { display: flex; gap: 0.75rem; margin-top: 1.75rem; }
      .survey-btn { padding: 0.75rem 1.75rem; background: linear-gradient(135deg, #2563EB, #3B82F6); color: #fff; font-weight: 700; border-radius: 10px; border: none; cursor: pointer; font-size: 1rem; font-family: 'Inter', sans-serif; box-shadow: 0 4px 12px rgba(37,99,235,0.25); transition: transform 0.15s, box-shadow 0.15s; }
      .survey-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(37,99,235,0.3); }
      .survey-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
      .survey-btn-secondary { background: #fff; color: #2563EB; border: 2px solid #2563EB; box-shadow: none; }
      .survey-btn-secondary:hover { background: #EFF6FF; }
      .survey-page { display: none; }
      .survey-page.active { display: block; }
      .survey-intro-text { font-size: 1rem; font-weight: 600; color: #374151; line-height: 1.65; margin-bottom: 1.25rem; }
      .survey-intro-text strong { color: #2563EB; }
      .niche-carousel-wrap { max-width: 480px; margin: 0 auto 1.25rem; width: 100%; }
      .niche-set { display: none; grid-template-columns: repeat(3, 1fr); gap: 10px; }
      .niche-set.active { display: grid; animation: niche-fade-in 0.4s ease; }
      .niche-set img { width: 100%; aspect-ratio: 921 / 1086; object-fit: cover; border-radius: 12px; border: 1px solid #E2E8F0; }
      .niche-nav { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 14px; }
      .niche-arrow { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; flex-shrink: 0; border-radius: 50%; border: 1px solid #E2E8F0; background: #fff; color: #2563EB; font-size: 1.25rem; line-height: 1; cursor: pointer; user-select: none; -webkit-tap-highlight-color: transparent; transition: background 0.2s, color 0.2s, transform 0.15s, border-color 0.2s; }
      .niche-arrow:hover { background: #2563EB; color: #fff; border-color: #2563EB; transform: scale(1.08); }
      .niche-arrow:active { transform: scale(0.95); }
      .niche-label { min-width: 140px; text-align: center; font-size: 0.95rem; font-weight: 600; color: #374151; user-select: none; -webkit-tap-highlight-color: transparent; }
      .niche-label.niche-label-anim { animation: niche-label-in 0.35s ease; }
      @keyframes niche-label-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
      @keyframes niche-fade-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
      @media (max-width: 768px) {
        body { background: #fff !important; }
        .survey-wrap { padding: 1rem 1.25rem; justify-content: flex-start; }
        .survey-card { background: transparent; box-shadow: none; border-radius: 0; padding: 1.25rem 0; max-width: 100%; }
      }
    </style>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NTGWNM69"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Loading overlay while subscribing -->
    <div id="survey-loader" style="display:flex; position:fixed; inset:0; background:#F1F5F9; z-index:999; flex-direction:column; align-items:center; justify-content:center; gap:1rem;">
      <div style="width:44px; height:44px; border:4px solid #E2E8F0; border-top-color:#2563EB; border-radius:50%; animation:spin 0.8s linear infinite;"></div>
      <p style="color:#6B7280; font-family:'Inter',sans-serif; font-size:1rem;">Just a moment...</p>
    </div>
    <style>@keyframes spin { to { transform: rotate(360deg); } }</style>

    <div class="survey-wrap" id="survey-content" style="display:none;">
      <div class="survey-card">

        <div style="text-align:center; margin-bottom:1.25rem;">
          <div style="display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:0.75rem;">
            <img src="/Droparabia.png" alt="Droparabia" style="height:72px;" />
            <span style="font-family:'IBrand', sans-serif; font-size:3rem; font-weight:400; color:#0f172a;">Droparabia</span>
          </div>
 
        </div>

        <div class="survey-progress-track">
          <div class="survey-progress-bar" id="progress-bar" style="width:14.28%"></div>
        </div>

        <!-- Q0: Intro -->
        <div class="survey-page active" data-field="intro">
          <div class="survey-intro-text">
            <p>Droparabia helps you find hundreds of winning products that have demand in the Lebanese market and deliver them to your customers directly!</p>
            <p style="margin-top:0.75rem;"><strong>You only focus on marketing and advertising!</strong></p>
          </div>
          <div class="niche-carousel-wrap">
            <div class="niche-carousel">
              <div class="niche-set active" data-niche="health">
                <img src="/products/r1.webp" alt="" loading="lazy" />
                <img src="/products/r2.webp" alt="" loading="lazy" />
                <img src="/products/r4.webp" alt="" loading="lazy" />
              </div>
              <div class="niche-set" data-niche="kitchen">
                <img src="/products/k1.png" alt="" loading="lazy" />
                <img src="/products/k2.png" alt="" loading="lazy" />
                <img src="/products/k3.png" alt="" loading="lazy" />
              </div>
              <div class="niche-set" data-niche="gadgets">
                <img src="/products/g1.png" alt="" loading="lazy" />
                <img src="/products/g2.png" alt="" loading="lazy" />
                <img src="/products/g3.png" alt="" loading="lazy" />
              </div>
              <div class="niche-set" data-niche="pets">
                <img src="/products/p1.png" alt="" loading="lazy" />
                <img src="/products/p2.png" alt="" loading="lazy" />
                <img src="/products/p3.png" alt="" loading="lazy" />
              </div>
            </div>
            <div class="niche-nav">
              <button class="niche-arrow niche-arrow-prev" type="button" aria-label="Previous niche">&#8249;</button>
              <span class="niche-label">Health &amp; Beauty</span>
              <button class="niche-arrow niche-arrow-next" type="button" aria-label="Next niche">&#8250;</button>
            </div>
          </div>
        </div>

        <!-- Q1 -->
        <div class="survey-page" data-field="stopped" style="display:none">
          <h2 class="survey-question">What stopped you from starting your own e-commerce or dropshipping business?</h2>
          <div class="survey-options">
            <button class="survey-option" data-value="knowledge">Lack of experience or knowledge</button>
            <button class="survey-option" data-value="fear">Fear of loosing my money</button>
            <button class="survey-option" data-value="never">Never thought about it</button>
          </div>
          <div class="survey-error" id="err-1">Please select an option to continue</div>
        </div>

        <!-- Q2 -->
        <div class="survey-page" data-field="courses" style="display:none">
          <h2 class="survey-question">Have you purchased any kind of dropshipping/e-com courses or mentorships?</h2>
          <div class="survey-options">
            <button class="survey-option" data-value="yes">Yes</button>
            <button class="survey-option" data-value="no">No</button>
          </div>
          <div class="survey-error" id="err-2">Please select an option to continue</div>
        </div>

        <!-- Q3 -->
        <div class="survey-page" data-field="goalIncome" style="display:none">
          <h2 class="survey-question">What's your monthly goal income?</h2>
          <div class="survey-options">
            <button class="survey-option" data-value="upTo1k">Up to $1,000</button>
            <button class="survey-option" data-value="1kTo3k">$1,000 – $3,000</button>
            <button class="survey-option" data-value="3kTo5k">$3,000 – $5,000</button>
            <button class="survey-option" data-value="5kPlus">$5,000+</button>
          </div>
          <div class="survey-error" id="err-3">Please select an option to continue</div>
        </div>

        <!-- Q4 -->
        <div class="survey-page" data-field="effort" style="display:none">
          <h2 class="survey-question">Droparabia, our community and our expert team of advisors will help you reach that income goal but only if you're ready to work hard for it<br><br>Are you willing to put in the effort?</h2>
          <div class="survey-options">
            <button class="survey-option" data-value="hardWork">Yes I'll work hard</button>
            <button class="survey-option" data-value="doWhatICan">I'll do what I can</button>
          </div>
          <div class="survey-error" id="err-4">Please select an option to continue</div>
        </div>

        <!-- Q5 -->
        <div class="survey-page" data-field="budget" style="display:none">
          <h2 class="survey-question">We recommend that you have a sufficient budget of $600~$700 for marketing and advertising to ensure the best results possible<br><br>Do you have a budget ready for your business?</h2>
          <div class="survey-options">
            <button class="survey-option" data-value="yes">Yes I have the funds</button>
            <button class="survey-option" data-value="partial">I have at least $600</button>
            <button class="survey-option" data-value="no">No I don't have the funds :(</button>
          </div>
          <div class="survey-error" id="err-5">Please select an option to continue</div>
        </div>

        <!-- Q6 -->
        <div class="survey-page" data-field="contact" style="display:none">
          <h2 class="survey-question">That's great! In order to create your Droparabia account and book you a call, we need your:</h2>
          <div class="survey-inputs">
            <input type="text" class="survey-input" id="input-name" placeholder="First and Last Name" autocomplete="name" />
            <input type="email" class="survey-input" id="input-email" placeholder="Email Address" autocomplete="email" />
            <input type="tel" class="survey-input" id="input-phone" placeholder="Phone Number (e.g. 70 123 456)" autocomplete="tel" />
          </div>
          <div class="survey-error" id="err-6">Please fill in your name, a valid email and a valid phone number</div>
        </div>

        <div class="survey-nav">
          <button class="survey-btn survey-btn-secondary" id="btn-prev" style="display:none" onclick="prevPage()">← Previous</button>
          <button class="survey-btn" id="btn-next" onclick="nextPage()">Next →</button>
        </div>

      </div>
    </div>

    <script is:inline>
      var page = 0;
      var total = 7;
      var answers = {};

      function isValidLebanesePhone(raw) {
        var d = raw.replace(/[\s\-()+.]/g, '');
        if (d.startsWith('00961')) d = d.slice(5);
        else if (d.startsWith('961') && d.length >= 10) d = d.slice(3);
        if (d.startsWith('0')) d = d.slice(1);
        return /^\d{7,8}$/.test(d);
      }

      function isValidEmail(raw) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(raw);
      }

      // Mark survey as started and reveal it
      (function() {
        try {
          var tokens = JSON.parse(sessionStorage.getItem('userTokens') || '{}');
          tokens.takeSurvey = Math.random().toString(36).substring(2) + Date.now().toString(36);
          sessionStorage.setItem('userTokens', JSON.stringify(tokens));
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'survey_started' });
        } catch(_) {}

        // If they already gave their info to watch the VSL, prefill the contact fields
        try {
          var existingUserData = JSON.parse(sessionStorage.getItem('userData') || '{}');
          if (existingUserData.name)  document.getElementById('input-name').value  = existingUserData.name;
          if (existingUserData.email) document.getElementById('input-email').value = existingUserData.email;
          if (existingUserData.phone) document.getElementById('input-phone').value = existingUserData.phone;
        } catch(_) {}

        document.getElementById('survey-loader').style.display = 'none';
        document.getElementById('survey-content').style.display = 'flex';
        updateUI();
      })();

      // Product niche carousel (intro page)
      (function() {
        var niches = ['health', 'kitchen', 'gadgets', 'pets'];
        var labels = { health: 'Health & Beauty', kitchen: 'Kitchen', gadgets: 'Gadgets', pets: 'Pets' };
        document.querySelectorAll('.niche-carousel-wrap').forEach(function (wrap) {
          var sets = wrap.querySelectorAll('.niche-set');
          var labelEl = wrap.querySelector('.niche-label');
          var prevBtn = wrap.querySelector('.niche-arrow-prev');
          var nextBtn = wrap.querySelector('.niche-arrow-next');
          var current = 0;

          function show(index) {
            var niche = niches[index];
            sets.forEach(function (s) {
              s.classList.toggle('active', s.getAttribute('data-niche') === niche);
            });
            labelEl.classList.remove('niche-label-anim');
            labelEl.textContent = labels[niche];
            requestAnimationFrame(function () {
              labelEl.classList.add('niche-label-anim');
            });
          }

          if (prevBtn && nextBtn && labelEl) {
            prevBtn.addEventListener('click', function () {
              current = (current - 1 + niches.length) % niches.length;
              show(current);
            });
            nextBtn.addEventListener('click', function () {
              current = (current + 1) % niches.length;
              show(current);
            });
          }
        });
      })();

      // Option selection
      document.querySelectorAll('.survey-options').forEach(function(opts) {
        opts.addEventListener('click', function(e) {
          var btn = e.target.closest('.survey-option');
          if (!btn) return;
          opts.querySelectorAll('.survey-option').forEach(function(b) { b.classList.remove('selected'); });
          btn.classList.add('selected');
          var field = btn.closest('.survey-page').dataset.field;
          answers[field] = btn.dataset.value;
          document.getElementById('err-' + page).style.display = 'none';
        });
      });

      function updateUI() {
        var pages = document.querySelectorAll('.survey-page');
        pages.forEach(function(p, i) { p.style.display = i === page ? 'block' : 'none'; });
        document.getElementById('progress-bar').style.width = (((page + 1) / total) * 100) + '%';
        document.getElementById('btn-prev').style.display = page > 0 ? 'inline-block' : 'none';
        var btn = document.getElementById('btn-next');
        if (page === 0) btn.textContent = "That's amazing!";
        else if (page === total - 1) btn.textContent = 'Complete ✓';
        else btn.textContent = 'Next →';
      }

      function prevPage() {
        if (page > 0) { page--; updateUI(); }
      }

      function nextPage() {
        var pages = document.querySelectorAll('.survey-page');
        var field = pages[page].dataset.field;

        if (field === 'intro') {
          page++;
          updateUI();
          return;
        }

        if (field === 'contact') {
          var nameVal  = document.getElementById('input-name').value.trim();
          var emailVal = document.getElementById('input-email').value.trim();
          var phoneVal = document.getElementById('input-phone').value.trim();

          if (!nameVal || !isValidEmail(emailVal) || !isValidLebanesePhone(phoneVal)) {
            document.getElementById('err-6').style.display = 'block';
            return;
          }
          document.getElementById('err-6').style.display = 'none';

          sessionStorage.setItem('userData', JSON.stringify({ name: nameVal, email: emailVal, phone: phoneVal }));
          sessionStorage.setItem('da_subscribed', '1');
          answers.contact = true;

          // Complete
          var btn = document.getElementById('btn-next');
          btn.disabled = true;
          btn.textContent = 'Processing...';

          var qualified = answers.budget !== 'no';

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'survey_completed', survey_qualified: qualified, user_name: nameVal, user_email: emailVal, user_phone: phoneVal });

          var tokens = JSON.parse(sessionStorage.getItem('userTokens') || '{}');
          var token = Math.random().toString(36).substring(2) + Date.now().toString(36);
          tokens[qualified ? 'qualified' : 'unqualified'] = token;
          sessionStorage.setItem('userTokens', JSON.stringify(tokens));

          var list = qualified ? 'qualified_no_book' : 'unqualified';
          var utmKeys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
          var utms = {};
          utmKeys.forEach(function(k) { var v = sessionStorage.getItem(k); if (v) utms[k] = v; });
          var ref = sessionStorage.getItem('da_referrer') || '';

          fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(Object.assign({ name: nameVal, email: emailVal, phone: phoneVal, list: list, referrer: ref, cta_popup: sessionStorage.getItem('da_cta_popup') || '' }, utms)),
          }).finally(function() {
            window.location.href = qualified ? '/choose-schedule' : '/get-free-program';
          });
          return;
        }

        if (!answers[field]) {
          document.getElementById('err-' + page).style.display = 'block';
          return;
        }
        page++;
        updateUI();
      }

      window.addEventListener('beforeunload', function() {
        if (page < total - 1 || !answers.contact) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'survey_abandoned' });
        }
      });
    </script>
  </body>
</html>
