---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Start a successful online store with Droparabia!',
  description = 'Get a tour around Droparabia and learn how to leverage its powerful tools like the 400+ Lebanese who already built their online businesses.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>window.dataLayer = window.dataLayer || [];</script>
    <script is:inline>(function(){var p=new URLSearchParams(window.location.search);var hasUtm=false;['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach(function(k){var v=p.get(k);if(v){sessionStorage.setItem(k,v);hasUtm=true;}});if(!hasUtm&&!sessionStorage.getItem('da_referrer')&&document.referrer&&document.referrer.indexOf(window.location.hostname)===-1){sessionStorage.setItem('da_referrer',document.referrer);};}());</script>
    <!-- Google Tag Manager + gtag: deferred until first interaction (or 5s fallback) to keep them off the critical render path -->
    <script is:inline>
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-L1VGFRGHHN');

      function daLoadAnalytics(){
        if (window.__daLoaded) return;
        window.__daLoaded = true;
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-NTGWNM69');

        var gtagScript = document.createElement('script');
        gtagScript.async = true;
        gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-L1VGFRGHHN';
        document.head.appendChild(gtagScript);
      }

      ['scroll','mousemove','keydown','touchstart','click'].forEach(function(evt){
        window.addEventListener(evt, daLoadAnalytics, { once: true, passive: true });
      });
      setTimeout(daLoadAnalytics, 5000);
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" href="/Droparabia.png" type="image/png" />
    <link rel="shortcut icon" href="/Droparabia.png" type="image/png" />
    <link rel="apple-touch-icon" href="/Droparabia.png" />
    <meta property="og:image" content="https://droparabia.com/Droparabia.png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://droparabia.com" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content="https://droparabia.com/Droparabia.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NTGWNM69"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'IBrand';
    src: url('/fonts/ibrand.woff2') format('woff2'),
         url('/fonts/ibrand.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --blue: #2563eb;
    --blue-hover: #1d4ed8;
    --blue-light: #eff6ff;
    --blue-mid: #dbeafe;
    --blue-border: #bfdbfe;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-100: #f1f5f9;
    --gray-200: #e2e8f0;
    --gray-300: #cbd5e1;
    --gray-400: #94a3b8;
    --gray-500: #64748b;
    --gray-600: #475569;
    --gray-700: #334155;
    --gray-800: #1e293b;
    --gray-900: #0f172a;
    --font-body: 'Inter', 'Noto Sans', Arial, sans-serif;
    --font-brand: 'IBrand', 'Noto Sans', Arial, sans-serif;
    --radius-sm: 8px;
    --radius: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.07), 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08), 0 2px 6px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.10), 0 4px 16px rgba(0, 0, 0, 0.06);
    --shadow-blue: 0 8px 32px rgba(37, 99, 235, 0.20);
  }

  html {
    scroll-behavior: smooth;
    background: var(--white);
    overflow-x: hidden;
  }

  body {
    font-family: var(--font-body);
    color: var(--gray-900);
    background: var(--white) !important;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: var(--blue);
    text-decoration: none;
  }

  button {
    cursor: pointer;
    font-family: var(--font-body);
  }

  input, button {
    font-family: var(--font-body);
  }
</style>
